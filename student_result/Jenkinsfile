pipeline{
    agent any
    tools{
        jdk 'Java'
        maven 'Maven-3.9'
    }
    stages{
        stage('checkout'){
            steps{
                checkout scm
            }
        }
        stage('Build'){
            steps{
                sh 'mvn compile'
            }
        }
        stage('Test'){
            steps{
                sh 'mvn test'
            }
        }
        stage('Store jar file'){
            steps{
                sh 'mvn package'
            }
        }
    }
    post{
        success{
            archiveArtifacts artifacts:'target/*.jar'
            echo "build sucessfull"
        }
        failure{
           echo "build failed"
        }
    }
}